datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Project {
  id            String   @id @default(cuid())
  title         String
  description   String   @db.Text
  technologies  String[]
  liveDemoUrl   String
  sourceCodeUrl String
  imageUrl      String?
  createdAt     DateTime @default(now())
}
